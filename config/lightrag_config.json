{
  "embedding": {
    "model_name": "BAAI/bge-small-zh-v1.5",
    "device": "cpu",
    "batch_size": 32
  },
  "vector_store": {
    "type": "faiss",
    "dimension": 512,
    "metric": "cosine"
  },
  "retrieval": {
    "top_k": 10,
    "min_similarity": 0.5
  },
  "chunking": {
    "chunk_size": 512,
    "chunk_overlap": 50
  }
}
