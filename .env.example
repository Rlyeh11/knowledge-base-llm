# ========================================
# 知识库编译系统 - 环境变量配置示例
# ========================================
#
# 使用说明：
# 1. 复制此文件为 .env
#    cp .env.example .env
#
# 2. 根据你的需求填写环境变量
#
# 3. .env 文件包含敏感信息，已添加到 .gitignore
#    请不要提交 .env 文件到版本控制
#
# ========================================

# ========================================
# 模型配置
# ========================================

# 模型类型
# 选项: coze | openai | custom
# 说明:
#   - coze: 使用 Coze 平台的模型（豆包等）
#   - openai: 使用 OpenAI API 兼容的模型（DeepSeek, Kimi, OpenAI 等）
#   - custom: 使用自定义模型服务
# 必填: 是
# 默认值: 无
MODEL_TYPE=openai

# 模型 ID
# 说明: 要使用的具体模型标识符
# 常用值:
#   - deepseek-chat (DeepSeek)
#   - deepseek-coder (DeepSeek)
#   - moonshot-v1-8k (Kimi)
#   - moonshot-v1-32k (Kimi)
#   - gpt-4 (OpenAI)
#   - gpt-3.5-turbo (OpenAI)
#   - doubao-seed-1-8-251228 (豆包)
# 必填: 是
# 默认值: 无
MODEL_ID=deepseek-chat

# ========================================
# OpenAI API 配置
# ========================================

# OpenAI API Key
# 说明: 用于 OpenAI API 兼容服务的密钥
# 使用场景: DeepSeek, Kimi, OpenAI 等兼容 OpenAI API 的服务
# 获取方式: 从各平台获取 API Key
# 必填: MODEL_TYPE=openai 时必填
# 默认值: 无
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI API Base URL
# 说明: OpenAI API 的基础 URL
# 常用值:
#   - https://api.openai.com/v1 (OpenAI)
#   - https://api.deepseek.com/v1 (DeepSeek)
#   - https://api.moonshot.cn/v1 (Kimi)
# 必填: 否（使用默认值）
# 默认值: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.deepseek.com/v1

# OpenAI Organization ID（可选）
# 说明: OpenAI 组织 ID（仅 OpenAI 官方需要）
# 必填: 否
# 默认值: 无
OPENAI_ORGANIZATION_ID=

# ========================================
# Coze 平台配置
# ========================================

# Coze API Key
# 说明: Coze 平台的 API Key
# 使用场景: MODEL_TYPE=coze 时使用
# 获取方式: https://www.coze.cn/open
# 必填: MODEL_TYPE=coze 时必填
# 默认值: 无
COZE_API_KEY=your-coze-api-key-here

# Coze Workspace ID
# 说明: Coze 工作空间 ID
# 使用场景: MODEL_TYPE=coze 时使用
# 必填: MODEL_TYPE=coze 时必填
# 默认值: 无
COZE_WORKSPACE_ID=your-workspace-id-here

# Coze Bot ID
# 说明: Coze Bot ID（可选）
# 使用场景: 使用 Coze Bot 时需要
# 必填: 否
# 默认值: 无
COZE_BOT_ID=

# ========================================
# 服务配置
# ========================================

# 服务端口
# 说明: HTTP 服务监听的端口号
# 范围: 1024-65535
# 必填: 否
# 默认值: 5000
PORT=5000

# 服务主机
# 说明: HTTP 服务绑定的主机地址
# 常用值:
#   - 0.0.0.0 (允许外部访问)
#   - 127.0.0.1 (仅本地访问)
# 必填: 否
# 默认值: 0.0.0.0
HOST=0.0.0.0

# 日志级别
# 说明: 控制日志输出的详细程度
# 选项: DEBUG | INFO | WARNING | ERROR | CRITICAL
# DEBUG: 详细的调试信息
# INFO: 一般信息
# WARNING: 警告信息
# ERROR: 错误信息
# CRITICAL: 严重错误
# 必填: 否
# 默认值: INFO
LOG_LEVEL=INFO

# 日志文件路径
# 说明: 日志文件的存储路径
# 必填: 否
# 默认值: /app/work/logs/bypass/app.log
LOG_FILE_PATH=/app/work/logs/bypass/app.log

# 最大工作进程数
# 说明: 并发处理的最大任务数
# 范围: 1-16
# 说明: 根据服务器性能调整，建议设置为 CPU 核心数
# 必填: 否
# 默认值: 4
MAX_WORKERS=4

# 请求超时时间（秒）
# 说明: 单个请求的最大处理时间
# 范围: 60-3600
# 必填: 否
# 默认值: 900 (15分钟)
TIMEOUT_SECONDS=900

# ========================================
# 存储配置
# ========================================

# 存储类型
# 说明: 知识库数据的存储方式
# 选项: local | s3 | oss
# local: 本地文件系统
# s3: AWS S3 或兼容服务
# oss: 阿里云 OSS
# 必填: 否
# 默认值: local
STORAGE_TYPE=local

# 本地存储路径
# 说明: 知识库数据的本地存储目录
# 使用场景: STORAGE_TYPE=local 时使用
# 必填: STORAGE_TYPE=local 时必填
# 默认值: assets/knowledge_base
STORAGE_PATH=assets/knowledge_base

# S3 Access Key
# 说明: AWS S3 或兼容服务的访问密钥
# 使用场景: STORAGE_TYPE=s3 时使用
# 必填: STORAGE_TYPE=s3 时必填
# 默认值: 无
S3_ACCESS_KEY_ID=

# S3 Secret Access Key
# 说明: AWS S3 或兼容服务的秘密访问密钥
# 使用场景: STORAGE_TYPE=s3 时使用
# 必填: STORAGE_TYPE=s3 时必填
# 默认值: 无
S3_SECRET_ACCESS_KEY=

# S3 Bucket Name
# 说明: S3 存储桶名称
# 使用场景: STORAGE_TYPE=s3 时使用
# 必填: STORAGE_TYPE=s3 时必填
# 默认值: 无
S3_BUCKET_NAME=

# S3 Endpoint
# 说明: S3 服务端点
# 常用值:
#   - https://s3.amazonaws.com (AWS)
#   - https://s3.cn-north-1.amazonaws.com.cn (AWS 北京)
#   - https://cos.ap-beijing.myqcloud.com (腾讯云)
# 使用场景: STORAGE_TYPE=s3 时使用
# 必填: 否
# 默认值: https://s3.amazonaws.com
S3_ENDPOINT=

# S3 Region
# 说明: S3 服务区域
# 常用值: us-east-1, cn-north-1, ap-southeast-1
# 使用场景: STORAGE_TYPE=s3 时使用
# 必填: 否
# 默认值: us-east-1
S3_REGION=

# OSS Access Key ID
# 说明: 阿里云 OSS 访问密钥 ID
# 使用场景: STORAGE_TYPE=oss 时使用
# 必填: STORAGE_TYPE=oss 时必填
# 默认值: 无
OSS_ACCESS_KEY_ID=

# OSS Access Key Secret
# 说明: 阿里云 OSS 访问密钥 Secret
# 使用场景: STORAGE_TYPE=oss 时使用
# 必填: STORAGE_TYPE=oss 时必填
# 默认值: 无
OSS_ACCESS_KEY_SECRET=

# OSS Bucket Name
# 说明: 阿里云 OSS 存储桶名称
# 使用场景: STORAGE_TYPE=oss 时使用
# 必填: STORAGE_TYPE=oss 时必填
# 默认值: 无
OSS_BUCKET_NAME=

# OSS Endpoint
# 说明: 阿里云 OSS 服务端点
# 常用值:
#   - https://oss-cn-hangzhou.aliyuncs.com
#   - https://oss-cn-beijing.aliyuncs.com
# 使用场景: STORAGE_TYPE=oss 时使用
# 必填: 否
# 默认值: https://oss-cn-hangzhou.aliyuncs.com
OSS_ENDPOINT=

# ========================================
# 数据库配置（可选）
# ========================================

# 数据库 URL
# 说明: PostgreSQL 数据库连接字符串
# 格式: postgresql://user:password@host:port/database
# 使用场景: 需要持久化存储时使用
# 必填: 否
# 默认值: 无
DATABASE_URL=

# ========================================
# 缓存配置（可选）
# ========================================

# Redis URL
# 说明: Redis 连接字符串
# 格式: redis://localhost:6379/0
# 使用场景: 需要缓存时使用
# 必填: 否
# 默认值: 无
REDIS_URL=

# ========================================
# 安全配置
# ========================================

# API 认证密钥（可选）
# 说明: 用于 API 访问的认证密钥
# 使用场景: 需要保护 API 时使用
# 必填: 否
# 默认值: 无
API_SECRET_KEY=

# 允许的跨域来源（可选）
# 说明: 允许跨域访问的源地址
# 格式: 逗号分隔的 URL 列表
# 示例: https://example.com,https://www.example.com
# 使用场景: 生产环境限制跨域时使用
# 必填: 否
# 默认值: *
ALLOWED_ORIGINS=

# ========================================
# 特性开关
# ========================================

# 是否启用调试模式
# 说明: 开启后会显示详细的调试信息
# 选项: true | false
# 必填: 否
# 默认值: false
DEBUG=false

# 是否启用性能监控
# 说明: 开启后会记录性能指标
# 选项: true | false
# 必填: 否
# 默认值: false
ENABLE_METRICS=false

# 是否启用请求日志
# 说明: 开启后会记录所有 HTTP 请求
# 选项: true | false
# 必填: 否
# 默认值: true
ENABLE_REQUEST_LOG=true

# ========================================
# 其他配置
# ========================================

# 时区设置
# 说明: 系统使用的时区
# 常用值: Asia/Shanghai, UTC, America/New_York
# 必填: 否
# 默认值: Asia/Shanghai
TZ=Asia/Shanghai

# 语言设置
# 说明: 系统使用的语言
# 常用值: zh_CN, en_US
# 必填: 否
# 默认值: zh_CN
LANG=zh_CN

# 用户代理（可选）
# 说明: HTTP 请求时的 User-Agent
# 使用场景: 某些 API 需要特定的 User-Agent
# 必填: 否
# 默认值: Knowledge-Base-System/1.0
USER_AGENT=Knowledge-Base-System/1.0

# ========================================
# 配置示例
# ========================================

# DeepSeek 模型配置示例:
# MODEL_TYPE=openai
# MODEL_ID=deepseek-chat
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# LOG_LEVEL=INFO
# MAX_WORKERS=4

# Kimi 模型配置示例:
# MODEL_TYPE=openai
# MODEL_ID=moonshot-v1-8k
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# LOG_LEVEL=INFO
# MAX_WORKERS=4

# OpenAI 模型配置示例:
# MODEL_TYPE=openai
# MODEL_ID=gpt-4
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_ORGANIZATION_ID=org-xxxxxxxxxxxxxxxx
# LOG_LEVEL=INFO
# MAX_WORKERS=4

# 豆包模型配置示例:
# MODEL_TYPE=coze
# MODEL_ID=doubao-seed-1-8-251228
# COZE_API_KEY=your-coze-api-key
# COZE_WORKSPACE_ID=your-workspace-id
# LOG_LEVEL=INFO
# MAX_WORKERS=4

# ========================================
# 注意事项
# ========================================
#
# 1. .env 文件包含敏感信息，请勿提交到版本控制系统
# 2. 生产环境请使用更安全的密钥管理方式（如 Vault、AWS Secrets Manager）
# 3. API Key 和 Secret Key 请妥善保管，定期更换
# 4. 根据实际需求选择必需的环境变量
# 5. 非必需的环境变量可以留空或删除
#
# ========================================
